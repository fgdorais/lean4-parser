Param</a> <a href=\"./foundational_types.html\">(Type</a> u_3)</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\">self</span> : <span class=\"fn\"><a href=\"./Parser/Stream.html#Parser.Stream\">Parser.Stream</a> <span class=\"fn\">σ</span> <span class=\"fn\">τ</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">σ</span> → <span class=\"fn\"><span class=\"fn\"><a href=\"./Parser/Stream.html#Parser.Stream.Position\">Position</a> <span class=\"fn\">σ</span></span> → <span class=\"fn\">σ</span></span></span></div></div>","info":{"doc":"*Parser stream class*\n\nThis class extends the basic `Stream` class with position features needed by parsers for\nbacktracking and error reporting.\n\n* The type `Position` is used to record position data for the stream type.\n* `getPosition (s : σ) : Position` returns the current position of stream `s`.\n* `setPosition (s : σ) (p : Position) : σ` restores stream `s` to position `p`.\n\nImplementations should try to make the `Position` type as lightweight as possible for `getPosition`\nand `setPosition` to work properly. Often `Position` is just a scalar type or another simple type.\nThis may allow for parsers to use the stream state more efficiently.\n","docLink":"./Parser/Stream.html#Parser.Stream.setPosition","kind":"def","line":41,"name":"Parser.Stream.setPosition","sourceLink":"https://github.com/fgdorais/lean4-parser/blob/32c3d7e454ae0c2809ae885744ce3e6e2912136c/Parser/Stream.lean#L41-L41"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Parser/Stream.html#Parser.Stream.getPosition\"><span class=\"name\">Parser</span>.<span class=\"name\">Stream</span>.<span class=\"name\">getPosition</span></a></span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">σ</span> : <a href=\"./foundational_types.html\">Type</a> u_2}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">{<span class=\"fn\">τ</span> : <span class=\"fn\"><a href=\"./Init/Prelude.html#outParam\">outParam</a> <a href=\"./foundational_types.html\">(Type</a> u_3)</span>}</span></span>\n</span><span class=\"impl_arg\"><span class=\"decl_args\">\n<span class=\"fn\">[<span class=\"fn\">self</span> : <span class=\"fn\"><a href=\"./Parser/Stream.html#Parser.Stream\">Parser.Stream</a> <span class=\"fn\">σ</span> <span class=\"fn\">τ</span></span>]</span></span>\n</span><span class=\"decl_args\"> :</span><div class=\"decl_type\"><span class=\"fn\"><span class=\"fn\">σ</span> → <span class=\"fn\"><a href=\"./Parser/Stream.html#Parser.Stream.Position\">Position</a> <span class=\"fn\">σ</span></span></span></div></div>","info":{"doc":"*Parser stream class*\n\nThis class extends the basic `Stream` class with position features needed by parsers for\nbacktracking and error reporting.\n\n* The type `Position` is used to record position data for the stream type.\n* `getPosition (s : σ) : Position` returns the current position of stream `s`.\n* `setPosition (s : σ) (p : Position) : σ` restores stream `s` to position `p`.\n\nImplementations should try to make the `Position` type as lightweight as possible for `getPosition`\nand `setPosition` to work properly. Often `Position` is just a scalar type or another simple type.\nThis may allow for parsers to use the stream state more efficiently.\n","docLink":"./Parser/Stream.html#Parser.Stream.getPosition","kind":"def","line":40,"name":"Parser.Stream.getPosition","sourceLink":"https://github.com/fgdorais/lean4-parser/blob/32c3d7e454ae0c2809ae885744ce3e6e2912136c/Parser/Stream.lean#L40-L40"}},{"header":"<div class=\"decl_header\"><span class=\"decl_kind\">abbrev</span>\n<span class=\"decl_name\"><a class=\"break_within\" href=\"./Parser/Stream.html#Parser.Stream.Position\"><span class=\"